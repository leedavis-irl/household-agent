ANTHROPIC_API_KEY=your-api-key-here

# Home Assistant
HA_URL=http://your-ha-instance:8123
HA_TOKEN=your-ha-long-lived-access-token

# Signal
SIGNAL_ACCOUNT=+15550001234
SIGNAL_ENABLED=true
# Path to signal-cli binary. Mac default: /opt/homebrew/bin/signal-cli
# EC2 default: /opt/signal-cli-0.13.24/bin/signal-cli
# SIGNAL_CLI_PATH=/opt/signal-cli-0.13.24/bin/signal-cli
# Set to 'true' to write raw signal-cli JSON to /tmp/iji-signal-debug.log
# DEBUG_SIGNAL=false

# Slack (optional — Socket Mode, no public URL needed)
# Create a Slack app at api.slack.com/apps with Socket Mode enabled.
# Scopes needed: chat:write, app_mentions:read, channels:history, groups:history, im:history, im:read
# Event subscriptions: message.channels, message.groups, message.im, app_mention
SLACK_APP_TOKEN=xapp-...
SLACK_BOT_TOKEN=xoxb-...
# Set to 'false' to disable Slack channel
# SLACK_ENABLED=true
# Slack user token for slack_search tool (xoxp-... with search:read user scope)
# Required for the slack_search tool — bot tokens cannot use search.messages.
# Add search:read under "User Token Scopes" in your Slack app's OAuth settings.
# SLACK_USER_TOKEN=xoxp-...

# Twilio SMS (optional — needed for sms_send tool)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Monarch Money (unofficial API — reverse-engineered, TOTP MFA)
MONARCH_EMAIL=
MONARCH_PASSWORD=
MONARCH_TOTP_SECRET=
# Path to monarch-slack-integration state.json for payback ledger
# MONARCH_PAYBACKS_STATE_FILE=
# Override default session file location (default: data/monarch-session.json)
# MONARCH_SESSION_FILE=

# Education Advisor (Supabase — powers education_profile, education_documents, education_goals, education_team, education_upload)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Supabase Storage bucket name for uploaded education documents (default: education-documents)
# SUPABASE_EDUCATION_BUCKET=education-documents
# Google Gemini API key for AI-powered document metadata extraction (optional — education_upload works without it)
# GEMINI_API_KEY=AIza...

# Logging
# LOG_LEVEL=info

# CLI testing
# Override the default CLI user identity (default: lee)
# CLI_USER=lee

# Claude model for brain loop. Default: claude-sonnet-4-20250514
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Health check endpoint (localhost only). Default: 3001
# HEALTH_PORT=3001

# Brave Search API (web_search tool)
# Get a key at https://api.search.brave.com/
# Required for users with web_search permission
BRAVE_SEARCH_API_KEY=

# Task Tracker (ESP32 button-based routine tracker — kids' AM/PM chores)
# EC2 server running at http://<EC2_PUBLIC_IP>:8765
TASK_TRACKER_URL=http://<EC2_PUBLIC_IP>:8765

# Morning briefing scheduler
# Delivery time and recipients are configured per-person in config/household.json
# Set to 'false' to disable morning briefing without code changes
# BRIEFING_ENABLED=true
